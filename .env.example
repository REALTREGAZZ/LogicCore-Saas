# Environment Variables — LogiCore SaaS
# Copy this file to .env and fill in real values. NEVER commit .env to version control.

# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL with PostGIS extension enabled
DATABASE_URL=postgresql+asyncpg://logicore_user:strongpassword@localhost:5432/logicore_db

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_A_RANDOM_32_BYTE_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Cloudinary (Proof-of-Delivery image storage) ───────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── App Settings ────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
